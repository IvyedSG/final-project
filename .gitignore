# Unity .gitignore corregido para el proyecto Metal Slug VMT
# Basado en el template estándar de GitHub 2026

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Blender
*.blend1
*.blend1.meta

# Capturas y Grabaciones
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Plugins y Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio y IDEs
.vs/
.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# --- SECCIÓN CRÍTICA: EXCEPCIONES ---
# Forzamos que estas carpetas NUNCA sean ignoradas
!/[Aa]ssets/_Project/
!/[Aa]ssets/Scenes/
!/[Aa]ssets/_Project/Scenes/

# Comentamos las líneas del TestRunner que pueden causar conflictos con nombres de escenas
# # InitTestScene*.unity*
# # /[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Evitar ignorar archivos .unity y .meta dentro de Assets
!*.unity
!*.meta